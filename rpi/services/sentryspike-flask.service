[Unit]
Description=SentrySpike Flask Web Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/sentryspike
ExecStart=/opt/sentryspike/venv/bin/flask --app SentrySpike_Flask.web_service run --host=0.0.0.0 --port=5000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
